<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>R2AccessKeyId</key>
    <string>YOUR_R2_ACCESS_KEY_ID</string>
    <key>R2AccessKeySecret</key>
    <string>YOUR_R2_ACCESS_KEY_SECRET</string>
    <key>R2AccountId</key>
    <string>YOUR_CLOUDFLARE_ACCOUNT_ID</string>
    <key>R2BucketName</key>
    <string>your-bucket-name</string>
    <key>R2CustomDomain</key>
    <string>https://cdn.example.com</string>
    <key>MeilisearchHost</key>
    <string>https://your-project.meilisearch.io</string>
    <key>MeilisearchApiKey</key>
    <string>YOUR_MEILISEARCH_MASTER_KEY_OR_API_KEY</string>
</dict>
</plist>
